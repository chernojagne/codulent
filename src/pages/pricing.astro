---
import BaseLayout from '../layouts/BaseLayout.astro';

const tiers = [
  {
    name: 'Discovery',
    price: 'Free',
    priceNote: 'Initial consultation',
    description: 'A no-obligation call to understand your operations and identify the highest-impact automation opportunities.',
    features: [
      '60-minute discovery call',
      'High-level workflow assessment',
      'Automation opportunity identification',
      'Preliminary ROI estimate',
      'Written summary of recommendations',
    ],
    cta: 'Book Your Free Call',
    ctaHref: '/book',
    highlighted: false,
  },
  {
    name: 'Implementation',
    price: 'Custom',
    priceNote: 'Project-based pricing',
    description: 'Hands-on deployment and configuration of AI automation tailored to your specific business workflows.',
    features: [
      'Everything in Discovery, plus:',
      'Detailed process mapping & design',
      'OpenClaw or AI tool setup & configuration',
      'Custom integrations with your systems',
      'Testing, QA, and go-live support',
      'Team training & documentation',
    ],
    cta: 'Get a Quote',
    ctaHref: '/contact',
    highlighted: true,
  },
  {
    name: 'Ongoing Support',
    price: 'Custom',
    priceNote: 'Monthly retainer',
    description: 'Continuous monitoring, optimization, and expansion of your AI automation as your business evolves.',
    features: [
      'Everything in Implementation, plus:',
      'Proactive monitoring & alerting',
      'Performance tuning & optimization',
      'New automation expansions',
      'Priority support & office hours',
      'Monthly reporting & insights',
    ],
    cta: 'Discuss Retainer',
    ctaHref: '/contact',
    highlighted: false,
  },
];
---

<BaseLayout
  title="Pricing - Codulent AI Automation"
  description="Flexible engagement models from free discovery calls to full implementation and ongoing support. Get a custom quote for your AI automation needs."
>
  <!-- Hero -->
  <section class="bg-gradient-to-br from-navy-900 via-navy-800 to-navy-700 py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-accent-400 font-semibold text-sm tracking-wide uppercase mb-4">Pricing</p>
      <h1 class="text-4xl sm:text-5xl font-extrabold text-white">
        Flexible engagement, transparent value
      </h1>
      <p class="mt-6 text-lg text-slate-300 max-w-2xl mx-auto">
        Every business is different. We offer a range of engagement models to match your needs and budget.
      </p>
    </div>
  </section>

  <!-- Pricing Tiers -->
  <section class="py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-3 gap-8 items-start">
        {tiers.map((tier) => (
          <div
            class:list={[
              'relative rounded-2xl p-8 border',
              tier.highlighted
                ? 'border-accent-300 bg-accent-50/30 shadow-xl shadow-accent-100/50 ring-2 ring-accent-400'
                : 'border-slate-200 bg-white',
            ]}
          >
            {tier.highlighted && (
              <div class="absolute -top-3.5 left-1/2 -translate-x-1/2">
                <span class="inline-flex items-center px-3 py-1 rounded-full bg-accent-600 text-white text-xs font-semibold uppercase tracking-wide">
                  Most Popular
                </span>
              </div>
            )}
            <h3 class="text-xl font-bold text-navy-900">{tier.name}</h3>
            <div class="mt-4 flex items-baseline gap-2">
              <span class="text-4xl font-extrabold text-navy-900">{tier.price}</span>
            </div>
            <p class="text-sm text-slate-500 mt-1">{tier.priceNote}</p>
            <p class="mt-4 text-slate-600">{tier.description}</p>

            <ul class="mt-8 space-y-3">
              {tier.features.map((feature) => (
                <li class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-accent-600 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                  </svg>
                  <span class="text-sm text-slate-700">{feature}</span>
                </li>
              ))}
            </ul>

            <a
              href={tier.ctaHref}
              class:list={[
                'mt-8 block w-full text-center px-6 py-3 rounded-lg font-semibold transition-colors',
                tier.highlighted
                  ? 'bg-accent-600 text-white hover:bg-accent-700'
                  : 'bg-navy-700 text-white hover:bg-navy-800',
              ]}
            >
              {tier.cta}
            </a>
          </div>
        ))}
      </div>

      <!-- FAQ-like note -->
      <div class="mt-16 max-w-3xl mx-auto text-center">
        <p class="text-slate-500">
          All pricing is customized based on the scope and complexity of your automation needs.
          <a href="/contact" class="text-accent-700 font-semibold hover:text-accent-800"> Contact us</a> for a detailed proposal tailored to your business.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
