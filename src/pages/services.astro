---
import BaseLayout from '../layouts/BaseLayout.astro';

const services = [
  {
    id: 'assessment',
    icon: `<svg class="w-7 h-7 text-accent-700" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" /></svg>`,
    title: 'AI Operations Assessment',
    subtitle: 'Find where AI delivers the highest ROI',
    description: 'We start by deeply understanding your business operations. Through interviews, workflow mapping, and data analysis, we identify the processes that are costing you the most time and money - and design a prioritized automation roadmap.',
    features: [
      'Comprehensive workflow audit and process mapping',
      'Cost-benefit analysis for automation candidates',
      'Prioritized automation roadmap with ROI projections',
      'Technology stack recommendations',
      'Change management planning',
    ],
  },
  {
    id: 'openclaw',
    icon: `<svg class="w-7 h-7 text-accent-700" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 0 1 1.37.49l1.296 2.247a1.125 1.125 0 0 1-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7.723 7.723 0 0 1 0 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 0 1-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 0 1-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 0 1-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 0 1-1.369-.49l-1.297-2.247a1.125 1.125 0 0 1 .26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 0 1 0-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 0 1-.26-1.43l1.297-2.247a1.125 1.125 0 0 1 1.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.28Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" /></svg>`,
    title: 'OpenClaw Setup & Configuration',
    subtitle: 'Powerful AI task automation, configured for your needs',
    description: 'OpenClaw is a versatile AI automation platform capable of reading emails, processing documents, managing workflows, and much more. We handle the full deployment - from infrastructure setup to custom agent configuration - so you get a turnkey automation solution.',
    features: [
      'Full OpenClaw deployment and infrastructure setup',
      'Custom agent configuration for your specific workflows',
      'Email monitoring and automated response/action rules',
      'Document processing and data extraction pipelines',
      'Integration with your existing tools and systems',
    ],
  },
  {
    id: 'email',
    icon: `<svg class="w-7 h-7 text-accent-700" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" /></svg>`,
    title: 'Email & Communication Automation',
    subtitle: 'Never miss a critical message again',
    description: "Your inbox is a goldmine of actionable information - but manually processing it is a full-time job. We configure AI to read incoming email, categorize it by urgency and type, extract key data, and trigger the right actions automatically.",
    features: [
      'Automated email triage and categorization',
      'Smart routing to the right team or department',
      'Data extraction from emails and attachments',
      'Auto-generated responses for common inquiries',
      'Escalation rules for high-priority items',
    ],
  },
  {
    id: 'strategy',
    icon: `<svg class="w-7 h-7 text-accent-700" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5" /></svg>`,
    title: 'AI Strategy & Onboarding',
    subtitle: 'Get your entire team comfortable with AI',
    description: "Adopting AI isn't just about technology - it's about people. We provide hands-on training, documentation, and change management support to ensure your team embraces AI tools rather than resisting them.",
    features: [
      'Executive AI readiness workshops',
      'Team training on AI tools and workflows',
      'Custom documentation and runbooks',
      'Change management support and adoption planning',
      'Ongoing office hours and Q&A support',
    ],
  },
  {
    id: 'integrations',
    icon: `<svg class="w-7 h-7 text-accent-700" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244" /></svg>`,
    title: 'Custom Integrations',
    subtitle: 'Connect AI to the tools you already use',
    description: 'AI automation is most powerful when connected to your existing business systems. We build custom integrations between AI tools and your CRMs, ERPs, ticketing systems, communication platforms, and more.',
    features: [
      'CRM integration (Salesforce, HubSpot, etc.)',
      'ERP and accounting system connections',
      'Ticketing and helpdesk automation (Zendesk, Freshdesk)',
      'Slack, Teams, and communication platform bots',
      'Custom API development and webhook configuration',
    ],
  },
];
---

<BaseLayout
  title="Services - Codulent AI Automation"
  description="From AI operations assessment to OpenClaw setup, email automation, and custom integrations - explore how Codulent helps automate your business."
>
  <!-- Hero -->
  <section class="bg-gradient-to-br from-navy-900 via-navy-800 to-navy-700 py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-accent-400 font-semibold text-sm tracking-wide uppercase mb-4">Our Services</p>
      <h1 class="text-4xl sm:text-5xl font-extrabold text-white">
        AI automation, tailored to your business
      </h1>
      <p class="mt-6 text-lg text-slate-300 max-w-2xl mx-auto">
        We offer hands-on services from assessment to implementation - partnering with you to harness AI for real operational impact.
      </p>
    </div>
  </section>

  <!-- Services List -->
  <section class="py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="space-y-20">
        {services.map((service, index) => (
          <div id={service.id} class="scroll-mt-24">
            <div class:list={['grid lg:grid-cols-2 gap-12 items-start', index % 2 === 1 && 'lg:direction-rtl']}>
              <div class:list={[index % 2 === 1 && 'lg:direction-ltr']}>
                <div class="inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-accent-50 mb-6" set:html={service.icon} />
                <h2 class="text-3xl font-extrabold text-navy-900 mb-2">{service.title}</h2>
                <p class="text-lg text-accent-700 font-medium mb-4">{service.subtitle}</p>
                <p class="text-slate-600 leading-relaxed mb-6">{service.description}</p>
                <a
                  href="/contact"
                  class="inline-flex items-center text-accent-700 font-semibold hover:text-accent-800 transition-colors"
                >
                  Get started with {service.title.split(' ')[0].toLowerCase()}
                  <svg class="ml-1.5 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                  </svg>
                </a>
              </div>
              <div class:list={[index % 2 === 1 && 'lg:direction-ltr']}>
                <div class="bg-slate-50 border border-slate-200 rounded-2xl p-8">
                  <h3 class="text-sm font-semibold text-navy-700 uppercase tracking-wider mb-4">What's included</h3>
                  <ul class="space-y-3">
                    {service.features.map((feature) => (
                      <li class="flex items-start gap-3">
                        <svg class="w-5 h-5 text-accent-600 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                        </svg>
                        <span class="text-slate-700">{feature}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-gradient-to-r from-accent-600 to-accent-700">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl sm:text-4xl font-extrabold text-white">
        Not sure where to start?
      </h2>
      <p class="mt-4 text-lg text-accent-100 max-w-2xl mx-auto">
        Book a free discovery call and we'll help you identify the quickest wins for AI automation in your business.
      </p>
      <a
        href="/book"
        class="mt-8 inline-flex items-center justify-center px-8 py-4 rounded-lg bg-white text-accent-700 font-bold text-lg hover:bg-accent-50 transition-colors shadow-lg"
      >
        Book a Free Assessment
      </a>
    </div>
  </section>
</BaseLayout>
