---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Book a Free Assessment - Codulent AI Automation"
  description="Schedule a free assessment with Codulent. We'll review your workflows and show you where AI automation can save time and money."
>
  <!-- Calendly CSS + JS -->
  <link slot="head" href="https://assets.calendly.com/assets/external/widget.css" rel="stylesheet" />

  <!-- Hero -->
  <section class="bg-gradient-to-br from-navy-900 via-navy-800 to-navy-700 py-16 lg:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-accent-400 font-semibold text-sm tracking-wide uppercase mb-4">Free Assessment</p>
      <h1 class="text-4xl sm:text-5xl font-extrabold text-white">
        Book your free assessment
      </h1>
      <p class="mt-6 text-lg text-slate-300 max-w-2xl mx-auto">
        Pick a time that works for you. We'll review your workflows and identify the best opportunities for AI automation.
      </p>
    </div>
  </section>

  <!-- Calendly Embed -->
  <section class="py-12 lg:py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div
        class="calendly-inline-widget rounded-2xl overflow-hidden"
        data-url="https://calendly.com/cherno-jagne-codulent/free-assessment?hide_gdpr_banner=1"
        style="min-width:320px;height:700px;"
      ></div>
    </div>
  </section>

  <!-- What to Expect -->
  <section class="py-16 lg:py-20 bg-slate-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl sm:text-3xl font-extrabold text-navy-900 text-center mb-12">
        What to expect
      </h2>
      <div class="grid sm:grid-cols-3 gap-8">
        <div class="text-center">
          <div class="w-12 h-12 rounded-xl bg-accent-100 flex items-center justify-center mx-auto mb-4">
            <span class="text-lg font-extrabold text-accent-700">1</span>
          </div>
          <h3 class="text-lg font-bold text-navy-900 mb-2">We listen</h3>
          <p class="text-sm text-slate-600">Tell us about your business, your workflows, and where things feel slow or manual.</p>
        </div>
        <div class="text-center">
          <div class="w-12 h-12 rounded-xl bg-accent-100 flex items-center justify-center mx-auto mb-4">
            <span class="text-lg font-extrabold text-accent-700">2</span>
          </div>
          <h3 class="text-lg font-bold text-navy-900 mb-2">We identify opportunities</h3>
          <p class="text-sm text-slate-600">We'll pinpoint specific tasks and processes where AI can make an immediate impact.</p>
        </div>
        <div class="text-center">
          <div class="w-12 h-12 rounded-xl bg-accent-100 flex items-center justify-center mx-auto mb-4">
            <span class="text-lg font-extrabold text-accent-700">3</span>
          </div>
          <h3 class="text-lg font-bold text-navy-900 mb-2">You get a clear plan</h3>
          <p class="text-sm text-slate-600">Walk away with a prioritized roadmap of automation opportunities - no obligation.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Calendly widget script -->
  <script is:inline src="https://assets.calendly.com/assets/external/widget.js"></script>
</BaseLayout>
