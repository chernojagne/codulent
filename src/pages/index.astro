---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Codulent - Your AI Automation Partner">
  <!-- Hero -->
  <section class="relative overflow-hidden bg-navy-900">
    <div class="absolute inset-0">
      <img
        src="/hero.webp"
        alt=""
        class="h-full w-full object-cover"
      />
    </div>
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-20 left-10 w-72 h-72 bg-accent-500 rounded-full blur-3xl"></div>
      <div class="absolute bottom-10 right-20 w-96 h-96 bg-accent-400 rounded-full blur-3xl"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 lg:py-36">
      <div class="max-w-3xl">
        <p class="bg-gradient-to-r from-accent-300 via-[#ff8a3d] to-[#ffd166] bg-clip-text text-transparent font-semibold text-sm tracking-wide uppercase mb-4">
          AI Automation Partner
        </p>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white leading-tight">
          Automate Your Business
          <span class="bg-gradient-to-r from-accent-300 via-[#ff8a3d] to-[#ffd166] bg-clip-text text-transparent"> with AI</span>
        </h1>
        <p class="mt-6 text-lg sm:text-xl text-slate-300 leading-relaxed max-w-2xl">
          Stop drowning in manual tasks. We help businesses onboard AI to streamline operations, reduce costs, and free your team to focus on what matters.
        </p>
        <div class="mt-10 flex flex-col sm:flex-row gap-4">
          <a
            href="/book"
            class="inline-flex items-center justify-center px-7 py-3.5 rounded-lg bg-accent-600 text-white font-semibold text-base hover:bg-accent-700 transition-colors shadow-lg shadow-accent-600/25"
          >
            Book a Free Assessment
            <svg class="ml-2 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </a>
          <a
            href="/services"
            class="inline-flex items-center justify-center px-7 py-3.5 rounded-lg border border-slate-500 text-white font-semibold text-base hover:bg-white/10 transition-colors"
          >
            Explore Services
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Problem / Solution -->
  <section class="py-20 lg:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <p class="text-accent-600 font-semibold text-sm tracking-wide uppercase mb-3">Why Automate?</p>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-navy-900">
          Your team is spending too much time on tasks AI can handle
        </h2>
        <p class="mt-4 text-lg text-slate-500">
          Manual processes slow you down. AI automation is no longer a luxury - it's a competitive necessity.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        <!-- Pain 1 -->
        <div class="relative p-8 rounded-2xl border border-slate-200 bg-slate-50 hover:shadow-lg transition-shadow">
          <div class="w-12 h-12 rounded-xl bg-red-100 flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-red-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-navy-900 mb-3">Repetitive Manual Work</h3>
          <p class="text-slate-600 leading-relaxed">
            Your team spends hours on data entry, email sorting, report generation, and other tasks that don't require human judgment.
          </p>
          <div class="mt-5 pt-5 border-t border-slate-200">
            <p class="text-sm font-semibold text-accent-700">With Codulent:</p>
            <p class="text-sm text-slate-600 mt-1">We deploy AI agents that handle these tasks automatically, 24/7.</p>
          </div>
        </div>

        <!-- Pain 2 -->
        <div class="relative p-8 rounded-2xl border border-slate-200 bg-slate-50 hover:shadow-lg transition-shadow">
          <div class="w-12 h-12 rounded-xl bg-amber-100 flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-amber-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 0 1 3 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 0 0-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 0 1-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 0 0 3 15h-.75M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm3 0h.008v.008H18V10.5Zm-12 0h.008v.008H6V10.5Z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-navy-900 mb-3">Rising Staffing Costs</h3>
          <p class="text-slate-600 leading-relaxed">
            Hiring more people to manage growing workloads isn't sustainable. Each new hire adds salary, benefits, and training overhead.
          </p>
          <div class="mt-5 pt-5 border-t border-slate-200">
            <p class="text-sm font-semibold text-accent-700">With Codulent:</p>
            <p class="text-sm text-slate-600 mt-1">Automate the workload equivalent of multiple team members - without the headcount.</p>
          </div>
        </div>

        <!-- Pain 3 -->
        <div class="relative p-8 rounded-2xl border border-slate-200 bg-slate-50 hover:shadow-lg transition-shadow">
          <div class="w-12 h-12 rounded-xl bg-purple-100 flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-purple-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-navy-900 mb-3">Information Overload</h3>
          <p class="text-slate-600 leading-relaxed">
            Emails, messages, documents, and tickets pile up. Critical items get buried and response times suffer.
          </p>
          <div class="mt-5 pt-5 border-t border-slate-200">
            <p class="text-sm font-semibold text-accent-700">With Codulent:</p>
            <p class="text-sm text-slate-600 mt-1">AI reads, prioritizes, and acts on incoming information so nothing falls through the cracks.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Overview -->
  <section class="py-20 lg:py-28 bg-slate-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <p class="text-accent-600 font-semibold text-sm tracking-wide uppercase mb-3">What We Do</p>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-navy-900">
          End-to-end AI automation services
        </h2>
        <p class="mt-4 text-lg text-slate-500">
          From strategy to implementation, we handle every step of bringing AI into your business.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <a href="/services#assessment" class="group p-6 rounded-2xl bg-white border border-slate-200 hover:border-accent-300 hover:shadow-lg transition-all">
          <div class="w-11 h-11 rounded-lg bg-accent-100 flex items-center justify-center mb-4 group-hover:bg-accent-200 transition-colors">
            <svg class="w-5 h-5 text-accent-700" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-navy-900 mb-2">AI Operations Assessment</h3>
          <p class="text-sm text-slate-600">We dig into your workflows and find the best automation opportunities.</p>
        </a>

        <a href="/services#openclaw" class="group p-6 rounded-2xl bg-white border border-slate-200 hover:border-accent-300 hover:shadow-lg transition-all">
          <div class="w-11 h-11 rounded-lg bg-accent-100 flex items-center justify-center mb-4 group-hover:bg-accent-200 transition-colors">
            <svg class="w-5 h-5 text-accent-700" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 0 1 1.37.49l1.296 2.247a1.125 1.125 0 0 1-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7.723 7.723 0 0 1 0 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 0 1-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 0 1-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 0 1-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 0 1-1.369-.49l-1.297-2.247a1.125 1.125 0 0 1 .26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 0 1 0-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 0 1-.26-1.43l1.297-2.247a1.125 1.125 0 0 1 1.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.28Z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-navy-900 mb-2">OpenClaw Setup</h3>
          <p class="text-sm text-slate-600">Deploy and configure OpenClaw for powerful task automation.</p>
        </a>

        <a href="/services#email" class="group p-6 rounded-2xl bg-white border border-slate-200 hover:border-accent-300 hover:shadow-lg transition-all">
          <div class="w-11 h-11 rounded-lg bg-accent-100 flex items-center justify-center mb-4 group-hover:bg-accent-200 transition-colors">
            <svg class="w-5 h-5 text-accent-700" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-navy-900 mb-2">Email Automation</h3>
          <p class="text-sm text-slate-600">AI reads, categorizes, and acts on email so you don't have to.</p>
        </a>

        <a href="/services#strategy" class="group p-6 rounded-2xl bg-white border border-slate-200 hover:border-accent-300 hover:shadow-lg transition-all">
          <div class="w-11 h-11 rounded-lg bg-accent-100 flex items-center justify-center mb-4 group-hover:bg-accent-200 transition-colors">
            <svg class="w-5 h-5 text-accent-700" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-navy-900 mb-2">AI Strategy & Training</h3>
          <p class="text-sm text-slate-600">Help your team understand and adopt AI tools with confidence.</p>
        </a>
      </div>

      <div class="mt-10 text-center">
        <a
          href="/services"
          class="inline-flex items-center text-accent-700 font-semibold hover:text-accent-800 transition-colors"
        >
          View all services
          <svg class="ml-1.5 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="py-20 lg:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <p class="text-accent-600 font-semibold text-sm tracking-wide uppercase mb-3">How It Works</p>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-navy-900">
          Three steps to automated operations
        </h2>
      </div>

      <div class="grid md:grid-cols-3 gap-8 lg:gap-12">
        <div class="text-center">
          <div class="w-16 h-16 rounded-2xl bg-navy-100 flex items-center justify-center mx-auto mb-6">
            <span class="text-2xl font-extrabold text-navy-700">1</span>
          </div>
          <h3 class="text-xl font-bold text-navy-900 mb-3">Assess</h3>
          <p class="text-slate-600">
            We audit your current workflows, identify bottlenecks, and map out which tasks are ripe for AI automation.
          </p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 rounded-2xl bg-navy-100 flex items-center justify-center mx-auto mb-6">
            <span class="text-2xl font-extrabold text-navy-700">2</span>
          </div>
          <h3 class="text-xl font-bold text-navy-900 mb-3">Configure</h3>
          <p class="text-slate-600">
            We set up and customize AI tools - including OpenClaw - to automate your identified workflows end-to-end.
          </p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 rounded-2xl bg-navy-100 flex items-center justify-center mx-auto mb-6">
            <span class="text-2xl font-extrabold text-navy-700">3</span>
          </div>
          <h3 class="text-xl font-bold text-navy-900 mb-3">Launch & Support</h3>
          <p class="text-slate-600">
            Go live with confidence. We monitor performance, fine-tune configurations, and train your team for long-term success.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust Signals -->
  <section class="py-16 bg-navy-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        <div>
          <p class="text-3xl lg:text-4xl font-extrabold text-white">AI-First</p>
          <p class="mt-2 text-sm text-slate-400">Approach to Automation</p>
        </div>
        <div>
          <p class="text-3xl lg:text-4xl font-extrabold text-white">Austin, TX</p>
          <p class="mt-2 text-sm text-slate-400">Based, Working Nationwide</p>
        </div>
        <div>
          <p class="text-3xl lg:text-4xl font-extrabold text-white">24/7</p>
          <p class="mt-2 text-sm text-slate-400">Automated Operations</p>
        </div>
        <div>
          <p class="text-3xl lg:text-4xl font-extrabold text-white">OpenClaw</p>
          <p class="mt-2 text-sm text-slate-400">Certified Experts</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="py-20 lg:py-28 bg-gradient-to-r from-accent-600 to-accent-700">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl sm:text-4xl font-extrabold text-white">
        Ready to put AI to work for your business?
      </h2>
      <p class="mt-4 text-lg text-accent-100 max-w-2xl mx-auto">
        Schedule a free discovery call and we'll show you exactly how AI can streamline your operations and reduce costs.
      </p>
      <a
        href="/book"
        class="mt-8 inline-flex items-center justify-center px-8 py-4 rounded-lg bg-white text-accent-700 font-bold text-lg hover:bg-accent-50 transition-colors shadow-lg"
      >
        Book Your Free Assessment
      </a>
    </div>
  </section>
</BaseLayout>
