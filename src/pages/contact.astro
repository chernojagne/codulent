---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact - Codulent AI Automation"
  description="Get in touch with Codulent to discuss how AI automation can transform your business. Book a free discovery call or send us a message."
>
  <!-- Hero -->
  <section class="bg-gradient-to-br from-navy-900 via-navy-800 to-navy-700 py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-accent-400 font-semibold text-sm tracking-wide uppercase mb-4">Contact</p>
      <h1 class="text-4xl sm:text-5xl font-extrabold text-white">
        Let's talk about automation
      </h1>
      <p class="mt-6 text-lg text-slate-300 max-w-2xl mx-auto">
        Ready to see what AI can do for your business? Fill out the form below or email us directly. We typically respond within one business day.
      </p>
    </div>
  </section>

  <!-- Contact Form + Info -->
  <section class="py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-5 gap-12 lg:gap-16">
        <!-- Form -->
        <div class="lg:col-span-3">
          <h2 class="text-2xl font-bold text-navy-900 mb-6">Send us a message</h2>
          <form
            action="https://formspree.io/f/your-form-id"
            method="POST"
            class="space-y-6"
            id="contact-form"
          >
            <div class="grid sm:grid-cols-2 gap-6">
              <div>
                <label for="name" class="block text-sm font-medium text-slate-700 mb-1.5">
                  Full Name <span class="text-red-500">*</span>
                </label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  class="w-full px-4 py-3 rounded-lg border border-slate-300 text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-accent-500 focus:border-accent-500 transition-colors"
                  placeholder="Jane Smith"
                />
              </div>
              <div>
                <label for="email" class="block text-sm font-medium text-slate-700 mb-1.5">
                  Email <span class="text-red-500">*</span>
                </label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  class="w-full px-4 py-3 rounded-lg border border-slate-300 text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-accent-500 focus:border-accent-500 transition-colors"
                  placeholder="jane@company.com"
                />
              </div>
            </div>
            <div>
              <label for="company" class="block text-sm font-medium text-slate-700 mb-1.5">
                Company
              </label>
              <input
                type="text"
                id="company"
                name="company"
                class="w-full px-4 py-3 rounded-lg border border-slate-300 text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-accent-500 focus:border-accent-500 transition-colors"
                placeholder="Acme Corp"
              />
            </div>
            <div>
              <label for="message" class="block text-sm font-medium text-slate-700 mb-1.5">
                How can we help? <span class="text-red-500">*</span>
              </label>
              <textarea
                id="message"
                name="message"
                required
                rows="5"
                class="w-full px-4 py-3 rounded-lg border border-slate-300 text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-accent-500 focus:border-accent-500 transition-colors resize-y"
                placeholder="Tell us about your business and what you're looking to automate..."
              ></textarea>
            </div>
            <button
              type="submit"
              class="inline-flex items-center justify-center px-7 py-3.5 rounded-lg bg-accent-600 text-white font-semibold text-base hover:bg-accent-700 transition-colors shadow-lg shadow-accent-600/25"
            >
              Send Message
              <svg class="ml-2 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 12 3.269 3.125A59.769 59.769 0 0 1 21.485 12 59.768 59.768 0 0 1 3.27 20.875L5.999 12Zm0 0h7.5" />
              </svg>
            </button>
          </form>
        </div>

        <!-- Contact Info -->
        <div class="lg:col-span-2">
          <h2 class="text-2xl font-bold text-navy-900 mb-6">Get in touch</h2>
          <div class="space-y-8">
            <!-- Email -->
            <div class="flex items-start gap-4">
              <div class="w-11 h-11 rounded-lg bg-accent-100 flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-accent-700" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
                </svg>
              </div>
              <div>
                <p class="font-semibold text-navy-900">Email</p>
                <a
                  href="mailto:info@codulent.com"
                  class="text-accent-700 hover:text-accent-800 transition-colors"
                >
                  info@codulent.com
                </a>
              </div>
            </div>

            <!-- Location -->
            <div class="flex items-start gap-4">
              <div class="w-11 h-11 rounded-lg bg-accent-100 flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-accent-700" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
                </svg>
              </div>
              <div>
                <p class="font-semibold text-navy-900">Location</p>
                <p class="text-slate-600">Austin, TX</p>
                <p class="text-sm text-slate-500">Working with clients nationwide</p>
              </div>
            </div>

            <!-- Response time -->
            <div class="flex items-start gap-4">
              <div class="w-11 h-11 rounded-lg bg-accent-100 flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-accent-700" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                </svg>
              </div>
              <div>
                <p class="font-semibold text-navy-900">Response Time</p>
                <p class="text-slate-600">Within 1 business day</p>
              </div>
            </div>
          </div>

          <!-- Free assessment callout -->
          <div class="mt-10 p-6 rounded-2xl bg-navy-50 border border-navy-200">
            <h3 class="font-bold text-navy-900 mb-2">Prefer to schedule a call?</h3>
            <p class="text-sm text-slate-600 mb-4">
              Book a free assessment and we'll review your automation opportunities - no strings attached.
            </p>
            <a
              href="/book"
              class="inline-flex items-center text-accent-700 font-semibold text-sm hover:text-accent-800 transition-colors"
            >
              Book a free assessment
              <svg class="ml-1.5 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
