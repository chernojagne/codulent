---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
---

<BaseLayout
  title="Blog — Codulent AI Automation Consulting"
  description="Insights on AI automation, OpenClaw, and how businesses can leverage AI to streamline operations and reduce costs."
>
  <!-- Hero -->
  <section class="bg-gradient-to-br from-navy-900 via-navy-800 to-navy-700 py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-accent-400 font-semibold text-sm tracking-wide uppercase mb-4">Blog</p>
      <h1 class="text-4xl sm:text-5xl font-extrabold text-white">
        Insights on AI & automation
      </h1>
      <p class="mt-6 text-lg text-slate-300 max-w-2xl mx-auto">
        Practical advice and thought leadership on bringing AI into your business operations.
      </p>
    </div>
  </section>

  <!-- Posts Grid -->
  <section class="py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {posts.map((post) => (
          <a
            href={`/blog/${post.id.replace(/\.md$/, '')}`}
            class="group block rounded-2xl border border-slate-200 bg-white overflow-hidden hover:shadow-lg hover:border-accent-300 transition-all"
          >
            <div class="p-8">
              <div class="flex items-center gap-3 mb-4">
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-accent-100 text-accent-700">
                  {post.data.category}
                </span>
                <span class="text-xs text-slate-400">
                  {post.data.publishDate.toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric',
                  })}
                </span>
              </div>
              <h2 class="text-xl font-bold text-navy-900 group-hover:text-accent-700 transition-colors mb-3">
                {post.data.title}
              </h2>
              <p class="text-slate-600 text-sm leading-relaxed">
                {post.data.excerpt}
              </p>
              <div class="mt-4 flex items-center text-accent-700 font-semibold text-sm">
                Read more
                <svg class="ml-1.5 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                </svg>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
