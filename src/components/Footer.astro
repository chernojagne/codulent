---
const currentYear = new Date().getFullYear();

const footerLinks = {
  services: [
    { label: 'AI Operations Assessment', href: '/services#assessment' },
    { label: 'OpenClaw Setup', href: '/services#openclaw' },
    { label: 'Email Automation', href: '/services#email' },
    { label: 'AI Strategy & Onboarding', href: '/services#strategy' },
    { label: 'Custom Integrations', href: '/services#integrations' },
  ],
  company: [
    { label: 'About', href: '/about' },
    { label: 'Case Studies', href: '/case-studies' },
    { label: 'Blog', href: '/blog' },
    { label: 'Pricing', href: '/pricing' },
    { label: 'Contact', href: '/contact' },
  ],
};
---

<footer class="bg-navy-900 text-slate-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">
      <!-- Brand -->
      <div class="lg:col-span-1">
        <a href="/" class="text-2xl font-extrabold text-white tracking-tight">
          Codulent
        </a>
        <p class="mt-4 text-sm leading-relaxed text-slate-400">
          Helping businesses automate operations with AI. Based in Austin, TX — working with clients nationwide.
        </p>
        <a
          href="mailto:info@codulent.com"
          class="mt-4 inline-block text-sm text-accent-400 hover:text-accent-300 transition-colors"
        >
          info@codulent.com
        </a>
      </div>

      <!-- Services -->
      <div>
        <h3 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">
          Services
        </h3>
        <ul class="space-y-2.5">
          {footerLinks.services.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm text-slate-400 hover:text-white transition-colors"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h3 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">
          Company
        </h3>
        <ul class="space-y-2.5">
          {footerLinks.company.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm text-slate-400 hover:text-white transition-colors"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- CTA -->
      <div>
        <h3 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">
          Ready to Automate?
        </h3>
        <p class="text-sm text-slate-400 mb-4">
          Book a free discovery call to learn how AI can transform your operations.
        </p>
        <a
          href="/contact"
          class="inline-flex items-center px-5 py-2.5 rounded-lg bg-accent-600 text-white text-sm font-semibold hover:bg-accent-700 transition-colors"
        >
          Book a Consultation
        </a>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-8 border-t border-navy-700 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-sm text-slate-500">
        &copy; {currentYear} Codulent, LLC. All rights reserved.
      </p>
      <div class="flex items-center gap-4">
        <!-- LinkedIn -->
        <a
          href="https://www.linkedin.com/company/codulent"
          target="_blank"
          rel="noopener noreferrer"
          class="text-slate-500 hover:text-white transition-colors"
          aria-label="Codulent on LinkedIn"
        >
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</footer>
